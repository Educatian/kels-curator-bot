DISCORD_TOKEN=replace_with_bot_token
DISCORD_CLIENT_ID=replace_with_application_client_id
DISCORD_GUILD_ID=replace_with_test_server_id

# Optional: post scheduled weekly digests to this channel.
DIGEST_CHANNEL_ID=
DIGEST_CRON_HOUR_LOCAL=9
DIGEST_TIME_ZONE=America/Los_Angeles

# Optional comma-separated channel names or IDs to index.
# Empty means the bot indexes any visible non-bot message in the server.
INDEX_CHANNELS=job_academic,job_practitioner,cfp-rfp,seminar-resource,academic-resources,study_workshop_bootcamp,conferencepresentations,newsletter,announcement,introduction

# Optional automatic reactions for indexed member posts and thread replies.
# Custom emoji can be configured by ID, Discord literal, or server emoji name; unicode emoji are used as-is.
AUTO_REACT_ENABLED=false
AUTO_REACT_EMOJIS=KELS,👍

DATA_DIR=./data

# Optional go-live helper: backfill configured INDEX_CHANNELS when the bot first becomes ready.
AUTO_BACKFILL_ON_READY=false
AUTO_BACKFILL_FORCE=false
AUTO_BACKFILL_LIMIT=50

# Optional public weekly OpenAlex recommendation: one article from the KELS journal pool.
# For KELS, point this to #academic-resources.
ARTICLE_DIGEST_ENABLED=false
ARTICLE_DIGEST_CHANNEL_ID=
ARTICLE_DIGEST_HOUR_LOCAL=10
ARTICLE_DIGEST_LOOKBACK_DAYS=365
OPENALEX_MAILTO=

# Optional public weekly arXiv tech-paper signal for research translation.
# For KELS, point this to #academic-resources.
TECH_SIGNAL_ENABLED=false
TECH_SIGNAL_CHANNEL_ID=
TECH_SIGNAL_WEEKDAY=Wed
TECH_SIGNAL_HOUR_LOCAL=10
TECH_SIGNAL_LOOKBACK_DAYS=14
TECH_SIGNAL_QUERY=
TECH_SIGNAL_GITHUB_ENABLED=true
TECH_SIGNAL_GITHUB_MIN_STARS=100
TECH_SIGNAL_GITHUB_QUERIES=llm education,rag education,ai agent education,learning analytics,multimodal learning,ai tutor

# Optional Field Explorer integration for /field-map.
# Best current source: Educatian/fieldexplorer1.0 src/data/venues.json.
# The parser also accepts older FieldExplorer index.tsx files with embedded csvData,
# Name,Type,Category CSV exports, or BERTopic Topic CSV files.
FIELD_EXPLORER_ENABLED=false
FIELD_EXPLORER_TOPICS_FILE=
FIELD_EXPLORER_LABEL=FieldExplorer
FIELD_EXPLORER_APP_URL=https://fieldexplorer10.vercel.app
# Live verified-CFP bridge: surfaces FieldExplorer's verified deadlines (D-day +
# source URL + verified date) inside /cfp-helper. Read-only Supabase access.
# Off until FIELD_EXPLORER_CFP_ENABLED=true and the URL/key are set.
FIELD_EXPLORER_CFP_ENABLED=false
FIELD_EXPLORER_SUPABASE_URL=
FIELD_EXPLORER_SUPABASE_KEY=
# Proactive CFP deadline alerts to a channel (D-30/14/7/1 by default).
FIELD_EXPLORER_CFP_ALERT_ENABLED=false
FIELD_EXPLORER_CFP_ALERT_CHANNEL_ID=
FIELD_EXPLORER_CFP_ALERT_HOUR_LOCAL=9
FIELD_EXPLORER_CFP_ALERT_DAYS=30,14,7,1
# Review write-bridge: /review posts a venue review into FieldExplorer's
# annotations table (shows in the app review feed). Annotations RLS has no insert
# policy, so this REQUIRES the Supabase SERVICE ROLE key. Off by default.
FIELD_EXPLORER_REVIEW_ENABLED=false
FIELD_EXPLORER_SUPABASE_SERVICE_KEY=
# Venue add-bridge: /add-venue inserts a new journal/conference into FieldExplorer's
# community_venues table (the app merges approved rows into its graph). Service-role.
FIELD_EXPLORER_ADD_VENUE_ENABLED=false
# Submission-fit scorecard for /venue-scout: ports FieldExplorer's fingerprint +
# methodology + CFP scorer. Point at the app's semantic_profiles.json. Off by default.
FIELD_EXPLORER_SCORECARD_ENABLED=false
FIELD_EXPLORER_PROFILES_FILE=C:\Users\jewoo\Documents\Playground\fieldexplorer1.0\src\data\semantic_profiles.json

# Optional public monthly Knowledge Flow summary for the community.
MONTHLY_RADAR_ENABLED=false
MONTHLY_RADAR_CHANNEL_ID=
MONTHLY_RADAR_HOUR_LOCAL=9

# Optional public deadline reminders for indexed CFP/RFP and opportunity deadlines.
DEADLINE_REMINDER_ENABLED=false
DEADLINE_REMINDER_CHANNEL_ID=
DEADLINE_REMINDER_HOUR_LOCAL=9
DEADLINE_REMINDER_DAYS=14,7,2

# Optional @everyone reminder one hour before timed events posted in announcement.
EVENT_REMINDER_ENABLED=false
EVENT_REMINDER_SOURCE_CHANNELS=announcement
EVENT_REMINDER_CHANNEL_ID=
EVENT_REMINDER_LOOKAHEAD_MINUTES=60
EVENT_REMINDER_POLL_MINUTES=10
EVENT_D1_REMINDER_ENABLED=true
EVENT_FOLLOWUP_ENABLED=true
EVENT_FOLLOWUP_WINDOW_MINUTES=1440

# Optional moderator DM suggestions for forum post tags/titles.
FORUM_SUGGESTION_ENABLED=false
MODERATOR_USER_IDS=

# Optional local Qwen/Ollama enhancement. Falls back to rule-based text when unavailable.
QWEN_ENABLED=false
QWEN_MODEL=qwen2.5-coder:7b
QWEN_BASE_URL=http://127.0.0.1:11434
QWEN_TIMEOUT_MS=60000

# Optional chatbot and Qwen interaction logging.
KELS_CHATBOT_LOGGING_ENABLED=false
KELS_LOG_WEBHOOK_URL=
KELS_LOG_WEBHOOK_TOKEN=

# Optional automatic role tagging from member messages.
# Existing roles are preferred. New roles are created with ROLE_PREFIX when no suitable role exists.
ROLE_AUTO_TAGGING_ENABLED=false
ROLE_AUTO_CREATE_ENABLED=false
ROLE_AUTO_ASSIGN_ENABLED=false
ROLE_MIN_CONFIDENCE=0.72
ROLE_AUTO_ASSIGN_CONFIDENCE=0.88
ROLE_AUTO_CREATE_CONFIDENCE=0.94
ROLE_MAX_PER_MEMBER=3
ROLE_PREFIX=KELS:
ROLE_IGNORE_NAMES=@everyone,KELS,Admin & Facilitator,CommunicationOfficer

# Optional onboarding automation for self-introduction messages.
ONBOARDING_ENABLED=false
ONBOARDING_CHANNEL_ID=
ONBOARDING_FOLLOWUP_ENABLED=true
ONBOARDING_FOLLOWUP_AFTER_DAYS=7
ROLELESS_REMINDER_ENABLED=false
ROLELESS_REMINDER_AFTER_DAYS=7
ROLELESS_REMINDER_HOUR_LOCAL=10
ROLELESS_FALLBACK_ROLE_NAME=KELS:OnboardingNeeded

# Optional ruthless spam cleanup for obvious spam patterns.
SPAM_AUTO_DELETE_ENABLED=false
SPAM_MAX_URLS=4
SPAM_MAX_MENTIONS=8

# Optional anonymous advice submission workflow.
# Members submit privately with /anon-submit, moderators review, then approved posts go to the public channel.
ANON_ADVICE_ENABLED=false
ANON_ADVICE_REVIEW_CHANNEL_ID=
ANON_ADVICE_POST_CHANNEL_ID=
ANON_ADVICE_DAILY_LIMIT=2
ANON_ADVICE_MIN_LENGTH=20
